# 拷贝一份叫 .env 放在 backend/ 下，按需改值。
# REPLACE_ 开头的都是占位符，上生产之前必须换掉。

APP_NAME=AstroGraph API
APP_ENV=dev                       # dev / staging / production

# --- 认证 ---
# 随机串，32 位起步。生成: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=REPLACE_WITH_AT_LEAST_32_RANDOM_CHARS_OR_LONGER_xxxxxxxxxxxx
AUTH_TOKEN_EXPIRE_HOURS=72
AUTH_ACCESS_TOKEN_MINUTES=30
AUTH_REFRESH_TOKEN_DAYS=14
AUTH_COOKIE_NAME=astro_refresh_token
# 生产必须 true；本地没 HTTPS 所以先 false
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
# 内部管理 API 的独立 token（/eval/*、capability-report 用）。留空就 fallback 回 AUTH_SECRET
ADMIN_TOKEN=

# 跨域白名单：生产换成明确域名，别偷懒写 *
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- 数据源 ---
CSV_READY=false
# 可以指 CSV 目录，也可以直接指一个 Excel 文件
CSV_ROOT=
# 图片根目录，多个用逗号
IMAGE_BASE_DIRS=
AUTO_LOAD_IMAGES_CATALOG=true
AUTO_BUILD_GRAPH_ON_STARTUP=true

TEXT_CORPUS_ROOT=
TEXT_CORPUS_AUTO_INGEST_ON_STARTUP=true

# 事实护栏规则文件（改完调 reload 就生效，不用重启）
DOMAIN_FACT_RULES_DEFAULT_PATH=backend/data/domain_fact_rules.default.jsonl
LOCAL_FACT_RULES_PATH=backend/data/local_fact_rules.jsonl
QUERY_EXPANSION_RULES_PATH=backend/data/query_expansion_rules.default.json

# --- Neo4j（可选）---
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# --- SQLite ---
SQLITE_PATH=astrograph.db
SQLITE_BUSY_TIMEOUT_MS=8000

# --- MinIO（可选）---
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=REPLACE_WITH_STRONG_PASSWORD
MINIO_SECURE=false
MINIO_BUCKET=astro-images

# --- Milvus（可选）---
MILVUS_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=astro_image_clip
MILVUS_AUTO_INDEX_ON_STARTUP=true

# --- CLIP 图像向量 ---
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k
CLIP_WARMUP_ON_STARTUP=true

# --- 本地 LLM ---
MODEL_ADAPTER_PATH=models/custom_model.py
MODEL_CLASS_NAME=AstroModel
STARWHISPER_ENABLED=false
STARWHISPER_MODEL_PATH=
STARWHISPER_TOKENIZER_PATH=
STARWHISPER_LAZY_LOAD=true
STARWHISPER_QUANTIZATION=none     # none / 4bit / 8bit
STARWHISPER_MAX_NEW_TOKENS=512
STARWHISPER_TEMPERATURE=0.3
STARWHISPER_TOP_P=0.9
STARWHISPER_CPU_OFFLOAD=true
STARWHISPER_OFFLOAD_DIR=tmp/starwhisper_offload
# 留空就按系统内存 80% 自动算；也可以手写例如 12GiB
STARWHISPER_MAX_CPU_MEMORY=
ASTRO_VISION_WARMUP_ON_STARTUP=true
ASTRO_VISION_WARMUP_DELAY_SECONDS=6

# 光谱多模态 caption 模型（可选）
SPECTRUM_ENABLED=true
SPECTRUM_MODEL_ID=AstroYuYang/Spectrum-Captioner
SPECTRUM_AUTO_DOWNLOAD=false

# --- 云端 LLM 兜底（可选）---
CLOUD_LLM_ENABLED=false
CLOUD_LLM_PROVIDER=openai
CLOUD_LLM_API_KEY=
CLOUD_LLM_MODEL=gpt-4o-mini
CLOUD_LLM_TIMEOUT_SECONDS=30

# --- 实时数据 ---
DYNAMIC_ENABLED=true
DYNAMIC_TIMEOUT_SECONDS=5
DYNAMIC_CACHE_TTL_HOURS=24
WEB_SEARCH_ENABLED=true
WEB_SEARCH_TIMEOUT_SECONDS=6

# --- 外部 API ---
MCP_TOOLS_ENABLED=true
MCP_TIMEOUT_SECONDS=6
# 去 https://api.nasa.gov/ 申请一个真的 key
MCP_NASA_API_KEY=REPLACE_WITH_REAL_NASA_API_KEY

# --- Agent 行为 ---
AGENT_ENABLE_LLM_PLANNER=false
AGENT_ENABLE_REFLECTION=true
AGENT_RETRIEVAL_TOP_K=5
AGENT_KB_MIN_SCORE=0.45

# --- 缓存（秒）---
RETRIEVAL_CACHE_TTL_SECONDS=1800
RETRIEVAL_CACHE_MAX_ENTRIES=512
GRAPH_QUERY_CACHE_TTL_SECONDS=1800
IMAGE_CACHE_TTL_SECONDS=1800
QA_CACHE_TTL_SECONDS=900

# --- 限流 / 超时 ---
QA_STREAM_TOTAL_TIMEOUT_SECONDS=45
QA_IMAGE_TIMEOUT_SECONDS=30
QA_RATE_LIMIT_PER_MINUTE=20
