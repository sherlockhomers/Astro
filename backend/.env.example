APP_NAME=AstroGraph API
APP_ENV=dev
CSV_READY=false
# 支持两种数据源：
# 1) CSV 目录（加载该目录下所有 *.csv）
# 2) 单个 Excel 文件（如 天文学数据集.xlsx，按 sheet 加载）
# Windows 示例：CSV_ROOT=E:/astronomical_dataset/astronomical-image-and-csv-dataset/天文学数据集.xlsx
CSV_ROOT=
# 当 CSV/Excel 内是相对图片路径时，可配置一个或多个图片根目录（逗号分隔）
# 示例：IMAGE_BASE_DIRS=F:/astronomical_dataset/astronomical-image-and-csv-dataset/data/images
IMAGE_BASE_DIRS=
# 若 CSV_ROOT 指向 Excel 且同目录存在 images_catalog.csv，可自动合并导入
AUTO_LOAD_IMAGES_CATALOG=true
AUTO_BUILD_GRAPH_ON_STARTUP=true
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
NEO4J_ENABLED=false
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
SQLITE_PATH=astrograph.db
AUTH_SECRET=change-this-secret
AUTH_TOKEN_EXPIRE_HOURS=72
MODEL_ADAPTER_PATH=models/custom_model.py
MODEL_CLASS_NAME=AstroModel
STARWHISPER_ENABLED=false
# 可填本地权重目录或 HuggingFace/ModelScope 已下载目录
STARWHISPER_MODEL_PATH=
STARWHISPER_TOKENIZER_PATH=
STARWHISPER_LAZY_LOAD=true
STARWHISPER_MAX_NEW_TOKENS=512
STARWHISPER_TEMPERATURE=0.3
STARWHISPER_TOP_P=0.9
STARWHISPER_CPU_OFFLOAD=true
STARWHISPER_OFFLOAD_DIR=tmp/starwhisper_offload
# 示例：12GiB；留空会自动按系统内存80%计算
STARWHISPER_MAX_CPU_MEMORY=
MINIO_ENABLED=false
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET=astro-images
MILVUS_ENABLED=false
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=astro_image_clip
CLIP_MODEL_NAME=ViT-B-32
CLIP_PRETRAINED=laion2b_s34b_b79k
DYNAMIC_ENABLED=true
DYNAMIC_TIMEOUT_SECONDS=5
DYNAMIC_CACHE_TTL_HOURS=24
