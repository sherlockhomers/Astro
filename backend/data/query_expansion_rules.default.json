{
  "_meta": {
    "description": "RetrievalService 的查询扩展规则。当用户查询命中 triggers 中任一关键词（大小写不敏感），会将 expansions 中未出现的词加到查询后面参与向量/BM25 检索，从而提升召回。",
    "example": {
      "triggers": ["黑洞", "black hole"],
      "expansions": ["事件视界", "奇点"]
    },
    "version": 1
  },
