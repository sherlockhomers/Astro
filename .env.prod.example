# 拷贝一份叫 .env.prod，然后把下面所有 REPLACE_ 开头的值换掉
# 启动: docker compose --env-file .env.prod -f docker-compose.prod.yml up -d

# JWT 签名密钥，至少 32 个随机字符
# 生成的办法: python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_AT_LEAST_32_CHARS

# Neo4j 图数据库
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# MinIO 对象存储
MINIO_ROOT_USER=REPLACE_WITH_USERNAME
MINIO_ROOT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Redis
REDIS_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# NASA API Key（APOD / NeoWs 都用这个），去 https://api.nasa.gov/ 申请
MCP_NASA_API_KEY=REPLACE_WITH_REAL_NASA_KEY

# 前端访问后端用的地址。带 http(s)://，末尾别加斜杠
VITE_API_BASE_URL=https://api.example.com

# 允许的跨域来源，逗号分隔；千万别用 *
ALLOWED_ORIGINS=https://example.com,https://www.example.com
